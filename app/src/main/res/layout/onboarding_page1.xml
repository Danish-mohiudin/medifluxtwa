<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Teal gradient full background -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_teal_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Decorative circle top-right -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/circle_teal_light"
        android:layout_marginTop="-70dp"
        android:layout_marginEnd="-70dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Decorative circle mid-left -->
    <View
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/circle_teal_light"
        android:layout_marginStart="-40dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/whiteCard"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Illustration in the teal area -->
    <ImageView
        android:id="@+id/illustration"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:src="@drawable/ic_onboarding_pharmacy"
        android:contentDescription="Pharmacy illustration"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/whiteCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ═══════════════════════════════════════════
         WHITE CARD — fixed at 52% of screen height
         ═══════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/whiteCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_white_rounded_top"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.52">

        <!-- Skip — top-right of white card -->
        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skip"
            android:textColor="#008080"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="12dp"
            android:paddingEnd="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Content block -->
        <LinearLayout
            android:id="@+id/content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/dotsRow"
            app:layout_constraintVertical_bias="0.0">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHARMACY MANAGEMENT"
                android:textColor="#008080"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.10"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your Pharmacy,\nSmarter"
                android:textColor="#0D2B2B"
                android:textSize="28sp"
                android:fontFamily="sans-serif-medium"
                android:lineSpacingMultiplier="1.15"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="An all-in-one solution built for Indian pharmacies. Manage sales, purchases, inventory, and GST billing — all from one place."
                android:textColor="#4A6060"
                android:textSize="13sp"
                android:fontFamily="sans-serif"
                android:lineSpacingMultiplier="1.55"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sales"
                    android:textColor="#008080"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/chip_teal_outline"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inventory"
                    android:textColor="#008080"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/chip_teal_outline"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Billing"
                    android:textColor="#008080"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/chip_teal_outline"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Dots row -->
        <LinearLayout
            android:id="@+id/dotsRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            app:layout_constraintBottom_toTopOf="@id/btnNext"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView android:id="@+id/dot0" android:layout_width="24dp" android:layout_height="8dp" android:layout_marginEnd="5dp" android:src="@drawable/dot_active"/>
            <ImageView android:id="@+id/dot1" android:layout_width="8dp"  android:layout_height="8dp" android:layout_marginEnd="5dp" android:src="@drawable/dot_inactive"/>
            <ImageView android:id="@+id/dot2" android:layout_width="8dp"  android:layout_height="8dp" android:src="@drawable/dot_inactive"/>
        </LinearLayout>

        <!-- Next button — full width, teal, pinned to bottom -->
        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="28dp"
            android:text="Next"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/btn_teal_rounded"
            android:stateListAnimator="@null"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
